# AI Copilot (OpenAI-compatible endpoint, e.g. OpenRouter)
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://openrouter.ai/api/v1"
OPENAI_MODEL="google/gemini-2.5-flash-lite"

# Public site URL used for SEO (canonical, sitemap, robots, Open Graph).
# Set this to your production domain.
NEXT_PUBLIC_SITE_URL="https://luca-nguyen.dev"

# GitHub API — used by the Source Control panel to show real repo stats.
# Generate a fine-grained PAT at: https://github.com/settings/tokens
# Required scopes: Contents (read), Metadata (read)
GITHUB_TOKEN=""
# Format: owner/repo  e.g. smoluca123/portfolio-ide
GITHUB_REPO=""
